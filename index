        .form-grupo label { margin-bottom: 5px; font-weight: bold; color: #ff9999; }
        .form-input, .form-textarea { padding: 10px; background-color: #1a1a1a; border: 1px solid #555; color: #fff; border-radius: 4px; font-size: 1em; }
        .form-textarea { resize: vertical; min-height: 100px; }
        .btn-enviar { background-color: #802020; color: white; border: none; padding: 12px 20px; font-size: 1em; font-weight: bold; border-radius: 4px; cursor: pointer; transition: 0.2s; }
        .btn-enviar:hover { background-color: #b33030; }
        
        .lista-comentarios { margin-top: 30px; background: rgba(20, 20, 20, 0.5); padding: 15px; border-radius: 6px; }
        .comentario-item { border-bottom: 1px solid #444; padding: 12px 0; }
        .comentario-item:last-child { border-bottom: none; }
        .comentario-autor { font-weight: bold; color: #ff6666; margin-bottom: 4px; }
        .comentario-data { font-size: 0.8em; color: #888; margin-left: 10px; }

        footer { text-align: center; margin-top: 40px; font-size: 0.8em; color: #aaa; padding: 10px; background: rgba(0,0,0,0.5); }
    </style>
</head>
<body>

<video autoplay muted loop id="video-fundo">
